# 复制为 .env(放在本 skill 目录),填好后用。不要提交真实密钥。
# 中间层 multi-channel-api 地址(create/edit/pull/A+ 都走它)
AMAZON_MCA_URL=http://localhost:8000
# 默认店铺(只允许白名单内;多店用 --store 切)
AMAZON_STORE=main
AMAZON_ALLOWED_STORES=main,qifengz,serenorch,bfpeaky
AMAZON_BRAND=Inkelligent
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
# 腾讯云 COS(create_listing / aplus create 传图用)
COS_SECRET_ID=请填写
COS_SECRET_KEY=请填写
COS_REGION=ap-guangzhou
COS_BUCKET=请填写(含APPID)
